# MIA — local development environment
# Copy to .env.development.local and fill in values.
# Real keys live in wrangler.toml (public vars) or wrangler secret put (secrets).

##################################
# CLOUDFLARE TURNSTILE
##################################
# Use the test sitekey locally — always passes, no domain restrictions needed.
# Real key is set in wrangler.toml as VITE_TURNSTILE_SITE_KEY.
# Test keys: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

##################################
# SECRETS — set via wrangler secret put in production
# For local wrangler dev, add these to .dev.vars (gitignored)
##################################
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
WILDAPRICOT_API_KEY=your-wa-api-key-here
RESEND_API_KEY=your-resend-api-key-here
